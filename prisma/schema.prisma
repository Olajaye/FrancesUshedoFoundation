generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Event {
  id               String        @id @default(uuid())
  title            String
  category         String
  date             String
  time             String
  location         String
  featured         Boolean       @default(false)
  image            String        @default("")
  description      String
  longDescription  String
  registrationLink String        @default("/donate")
  speakers         Json          @default("[]")
  agenda           Json          @default("[]")
  goals            Json          @default("[]")
  featuredCause    Boolean       @default(false)
  donationGoal     Float?
  goalCurrency     String?       @default("GBP")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  gallery          EventGallery?
}

model EventGallery {
  id        String   @id @default(uuid())
  eventId   String   @unique
  photos    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Donation {
  id        String   @id @default(uuid())
  name      String
  email     String
  amount    Float
  currency  String
  provider  String
  reference String   @unique
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  eventId   String?
  source    String?
}

model News {
  id          String   @id @default(uuid())
  title       String
  excerpt     String
  category    String
  date        DateTime
  postedTime  String   @default("")
  image       String   @default("")
  author      String
  authorRole  String   @default("")
  authorImage String   @default("")
  featured    Boolean  @default(false)
  hidden      Boolean  @default(false)
  tags        String[]
  content     String
  stats       Json     @default("[]")
  gallery     Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
